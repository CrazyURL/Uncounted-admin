# ── Client Configuration ───────────────────────────────────────────────

# 백엔드 API URL (uncounted-api 서버 주소)
VITE_API_URL=http://localhost:3001

# ── 암호화 키 (uncounted-api의 ENCRYPTION_KEY와 동일) ─────────────────────
VITE_ENCRYPTION_KEY=your-32-byte-hex-key-here

# ── Notes ──────────────────────────────────────────────────────────────
# 1. .env 파일을 루트에 생성하고 위 값들을 채우세요
# 2. 백엔드 환경변수는 uncounted-api/.env.example 참조
# 3. 프로덕션 배포 시 환경변수를 플랫폼 설정에서 관리하세요