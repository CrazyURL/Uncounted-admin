{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "incremental": true,
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "node",
    "paths": {
      "@capacitor/android": ["./node_modules/@capacitor/android"],
      "@capacitor/app": ["./node_modules/@capacitor/app"],
      "@capacitor/browser": ["./node_modules/@capacitor/browser"],
      "@capacitor/cli": ["./node_modules/@capacitor/cli"],
      "@capacitor/core": ["./node_modules/@capacitor/core"],
      "@capacitor/filesystem": ["./node_modules/@capacitor/filesystem"],
      "@capacitor/preferences":["./node_modules/@capacitor/preferences"],
      "@huggingface/transformers": ["./node_modules/@huggingface/transformers"],
      "framer-motion": ["./node_modules/framer-motion"],
      "react": ["./node_modules/react"],
      "react-dom": ["./node_modules/react-dom"],
      "react-router-dom": ["./node_modules/react-router-dom"]
    },
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"]
}
